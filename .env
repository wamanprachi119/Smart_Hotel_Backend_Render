# ── SmartHotel Backend Environment ───────────────────────────
# MySQL connection string — override appsettings.json in production
ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=smart_hotel;User=root;Password=root;

# ASP.NET Core environment (Development | Production)
ASPNETCORE_ENVIRONMENT=Development

# Port the backend listens on
ASPNETCORE_URLS=http://localhost:5000

# For production, set to your real values:
# ConnectionStrings__DefaultConnection=Server=prod-host;Port=3306;Database=smart_hotel;User=dbuser;Password=strongpassword;
# ASPNETCORE_ENVIRONMENT=Production
# ASPNETCORE_URLS=http://0.0.0.0:5000
